# ============================================================
#  Frontend .env — FinTrack Next.js
#  JANGAN commit file .env ke Git!
# ============================================================

# ── Development Lokal (npm run dev) ──────────────────────────────────────────
# Set ke URL Go API yang berjalan lokal
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Docker Production ─────────────────────────────────────────────────────────
# Kosongkan NEXT_PUBLIC_API_URL — Next.js rewrites yang handle proxy ke backend
# NEXT_PUBLIC_API_URL=""
# FINTRACK_API_INTERNAL_URL=http://fintrack-api:8080  ← diset di docker-compose.yml
